<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — ClinicaMvc</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #0F1117;
            color: #F1F5F9;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            min-height: 100vh;
        }

        /* ── SIDEBAR ── */
        .sidebar {
            width: 240px;
            min-height: 100vh;
            background-color: #1A1D27;
            border-right: 1px solid #2D3748;
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 100;
        }

        .sidebar-brand {
            padding: 1.5rem 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            border-bottom: 1px solid #2D3748;
        }

        .sidebar-brand-icon {
            width: 38px;
            height: 38px;
            background-color: #1e3a6e;
            border: 1px solid #2563EB;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #2563EB;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .sidebar-brand-text {
            font-size: 1rem;
            font-weight: 700;
            color: #F1F5F9;
            line-height: 1.2;
        }

            .sidebar-brand-text small {
                display: block;
                font-size: 0.7rem;
                color: #94A3B8;
                font-weight: 400;
            }

        .sidebar-nav {
            padding: 1rem 0.75rem;
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .sidebar-label {
            font-size: 0.7rem;
            color: #4A5568;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 0.5rem 0.5rem 0.25rem;
            margin-top: 0.5rem;
        }

        .nav-link-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.6rem 0.75rem;
            border-radius: 8px;
            color: #94A3B8;
            text-decoration: none;
            font-size: 0.9rem;
            transition: all 0.15s;
        }

            .nav-link-item:hover {
                background-color: #2D3748;
                color: #F1F5F9;
            }

            .nav-link-item.active {
                background-color: #1e3a6e;
                color: #2563EB;
                font-weight: 600;
            }

            .nav-link-item i {
                font-size: 1rem;
                width: 20px;
                text-align: center;
            }

        .sidebar-footer {
            padding: 1rem 0.75rem;
            border-top: 1px solid #2D3748;
        }

        .btn-logout {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.6rem 0.75rem;
            border-radius: 8px;
            color: #EF4444;
            background: none;
            border: none;
            width: 100%;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.15s;
        }

            .btn-logout:hover {
                background-color: #2d1515;
            }

        /* ── CONTEÚDO ── */
        .main-content {
            margin-left: 240px;
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .topbar {
            background-color: #1A1D27;
            border-bottom: 1px solid #2D3748;
            padding: 0.9rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .topbar-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #F1F5F9;
        }

        .topbar-user {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: #94A3B8;
            font-size: 0.875rem;
        }

            .topbar-user i {
                font-size: 1.3rem;
                color: #2563EB;
            }

        .page-body {
            padding: 2rem;
            flex: 1;
        }

        /* ── DASHBOARD CARDS ── */
        .stat-card {
            background-color: #1A1D27;
            border: 1px solid #2D3748;
            border-radius: 12px;
            padding: 1.25rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            flex-shrink: 0;
        }

        .stat-info {
            display: flex;
            flex-direction: column;
        }

        .stat-label {
            color: #94A3B8;
            font-size: 0.8rem;
        }

        .stat-value {
            font-size: 1.8rem;
            font-weight: 700;
            color: #F1F5F9;
            line-height: 1.2;
        }

        /* ── TABELA DASHBOARD ── */
        .dashboard-table-card {
            background-color: #1A1D27;
            border: 1px solid #2D3748;
            border-radius: 12px;
            overflow: hidden;
        }

        .table-card-header {
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #2D3748;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

            .table-card-header h5 {
                margin: 0;
                font-size: 1rem;
                font-weight: 600;
            }

        .btn-ver-todas {
            font-size: 0.8rem;
            color: #2563EB;
            text-decoration: none;
        }

            .btn-ver-todas:hover {
                text-decoration: underline;
            }

        .table-dark-custom {
            width: 100%;
            border-collapse: collapse;
        }

            .table-dark-custom th {
                background-color: #0F1117;
                color: #94A3B8;
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 0.05em;
                padding: 0.75rem 1.5rem;
                text-align: left;
            }

            .table-dark-custom td {
                padding: 0.85rem 1.5rem;
                border-top: 1px solid #2D3748;
                color: #F1F5F9;
                font-size: 0.875rem;
            }

            .table-dark-custom tr:hover td {
                background-color: #2D3748;
            }

        .badge-agendada {
            background-color: #1e3a6e;
            color: #2563EB;
            padding: 0.25rem 0.75rem;
            border-radius: 999px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .empty-state {
            padding: 3rem;
            text-align: center;
            color: #4A5568;
        }

            .empty-state i {
                font-size: 2.5rem;
                display: block;
                margin-bottom: 0.5rem;
            }

        /* ── FORMULÁRIOS ── */
        .form-card {
            background-color: #1A1D27;
            border: 1px solid #2D3748;
            border-radius: 12px;
            padding: 2rem;
        }

        .form-label {
            color: #94A3B8;
            font-size: 0.875rem;
        }

        .form-control, .form-select {
            background-color: #0F1117;
            border: 1px solid #2D3748;
            color: #F1F5F9;
            border-radius: 8px;
        }

            .form-control:focus, .form-select:focus {
                background-color: #0F1117;
                border-color: #2563EB;
                color: #F1F5F9;
                box-shadow: none;
            }

            .form-control::placeholder {
                color: #4A5568;
            }

            .form-select option {
                background-color: #1A1D27;
            }

        .btn-primary-custom {
            background-color: #2563EB;
            border: none;
            color: #fff;
            padding: 0.6rem 1.5rem;
            border-radius: 8px;
            font-weight: 600;
            transition: background-color 0.2s;
        }

            .btn-primary-custom:hover {
                background-color: #3B82F6;
                color: #fff;
            }

        .btn-secondary-custom {
            background-color: #2D3748;
            border: none;
            color: #94A3B8;
            padding: 0.6rem 1.5rem;
            border-radius: 8px;
            font-weight: 600;
            transition: background-color 0.2s;
        }

            .btn-secondary-custom:hover {
                background-color: #3D4A5C;
                color: #F1F5F9;
            }

        /* ── PAGE HEADER ── */
        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
        }

            .page-header h2 {
                font-size: 1.4rem;
                font-weight: 700;
                margin: 0;
            }

            .page-header p {
                color: #94A3B8;
                font-size: 0.875rem;
                margin: 0;
            }
        /* ── DETALHES ── */
        .detail-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.75rem 0;
            border-bottom: 1px solid #2D3748;
        }

            .detail-row:last-child {
                border-bottom: none;
            }

        .detail-label {
            color: #94A3B8;
            font-size: 0.875rem;
        }

        .detail-value {
            color: #F1F5F9;
            font-weight: 500;
            font-size: 0.9rem;
        }

    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon">
                <i class="bi bi-clipboard2-pulse"></i>
            </div>
            <div class="sidebar-brand-text">
                ClinicaMvc
                <small>Sistema de Consultas</small>
            </div>
        </div>

        <nav class="sidebar-nav">
            <span class="sidebar-label">Menu</span>

            <a asp-controller="Home" asp-action="Index"
               class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <a asp-controller="Medicos" asp-action="Index"
               class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Medicos" ? "active" : "")">
                <i class="bi bi-person-badge"></i> Médicos
            </a>

            <a asp-controller="Pacientes" asp-action="Index"
               class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Pacientes" ? "active" : "")">
                <i class="bi bi-people"></i> Pacientes
            </a>

            <a asp-controller="Consultas" asp-action="Index"
               class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Consultas" ? "active" : "")">
                <i class="bi bi-calendar-check"></i> Consultas
            </a>
        </nav>

        <div class="sidebar-footer">
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout">
                    <i class="bi bi-box-arrow-left"></i> Sair
                </button>
            </form>
        </div>
    </aside>

    <!-- CONTEÚDO PRINCIPAL -->
    <div class="main-content">
        <div class="topbar">
            <span class="topbar-title">@ViewData["Title"]</span>
            <div class="topbar-user">
                <i class="bi bi-person-circle"></i>
                @User.Identity?.Name
            </div>
        </div>

        <div class="page-body">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>