@model ClinicaMvc.Models.Paciente

@{
    ViewData["Title"] = "Detalhes do Paciente";
}

<h2>Detalhes do Paciente</h2>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <p><strong>Nome:</strong> @Model.Nome</p>
        <p><strong>CPF:</strong> @Model.CPF</p>
        <p><strong>Data de Nascimento:</strong> @Model.DataNascimento.ToString("dd/MM/yyyy")</p>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</div>