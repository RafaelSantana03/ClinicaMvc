@model ClinicaMvc.Models.Paciente

@{
    ViewData["Title"] = "Detalhes do Paciente";
}

<div class="page-header">
    <h2>Detalhes do Paciente</h2>
</div>

<div class="form-card" style="max-width: 500px;">
    <div class="detail-row">
        <span class="detail-label">Nome</span>
        <span class="detail-value">@Model.Nome</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">CPF</span>
        <span class="detail-value">@Model.CPF</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Data de Nascimento</span>
        <span class="detail-value">@Model.DataNascimento.ToString("dd/MM/yyyy")</span>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-custom">Editar</a>
    <a asp-action="Index" class="btn-secondary-custom">Voltar</a>
</div>