@model ClinicaMvc.Models.Paciente

@{
    ViewData["Title"] = "Excluir Paciente";
}

<h2>Excluir Paciente</h2>

<p class="text-danger">Tem certeza que deseja excluir o paciente abaixo?</p>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <p><strong>Nome:</strong> @Model.Nome</p>
        <p><strong>CPF:</strong> @Model.CPF</p>
        <p><strong>Data de Nascimento:</strong> @Model.DataNascimento.ToString("dd/MM/yyyy")</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirmar Exclusão</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>