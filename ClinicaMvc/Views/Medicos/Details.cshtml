@model ClinicaMvc.Models.Medico

@{
    ViewData["Title"] = "Detalhes do Médico";
}

<div class="page-header">
    <h2>Detalhes do Médico</h2>
</div>

<div class="form-card" style="max-width: 500px;">
    <div class="detail-row">
        <span class="detail-label">Nome</span>
        <span class="detail-value">@Model.Nome</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">CRM</span>
        <span class="detail-value">@Model.CRM</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Especialidade</span>
        <span class="detail-value">@Model.Especialidade</span>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-custom">Editar</a>
    <a asp-action="Index" class="btn-secondary-custom">Voltar</a>
</div>