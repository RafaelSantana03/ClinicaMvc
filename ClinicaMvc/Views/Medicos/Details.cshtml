@model ClinicaMvc.Models.Medico

@{
    ViewData["Title"] = "Detalhes do Médico";
}

<h2>Detalhes do Médico</h2>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <p><strong>Nome:</strong> @Model.Nome</p>
        <p><strong>CRM:</strong> @Model.CRM</p>
        <p><strong>Especialidade:</strong> @Model.Especialidade</p>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</div>