@model ClinicaMvc.Models.Medico

@{
    ViewData["Title"] = "Novo Médico";
}

<h2>Novo Médico</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="CRM" class="form-label"></label>
        <input asp-for="CRM" class="form-control" />
        <span asp-validation-for="CRM" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Especialidade" class="form-label"></label>
        <input asp-for="Especialidade" class="form-control" />
        <span asp-validation-for="Especialidade" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>