@model ClinicaMvc.Models.Medico

@{
    ViewData["Title"] = "Excluir Médico";
}

<div class="page-header">
    <h2>Excluir Médico</h2>
</div>

<p style="color:#EF4444; font-size:0.9rem;">
    <i class="bi bi-exclamation-triangle me-1"></i>
    Tem certeza que deseja excluir o médico abaixo? Esta ação não pode ser desfeita.
</p>

<div class="form-card" style="max-width: 500px;">
    <div class="detail-row">
        <span class="detail-label">Nome</span>
        <span class="detail-value">@Model.Nome</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">CRM</span>
        <span class="detail-value">@Model.CRM</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Especialidade</span>
        <span class="detail-value">@Model.Especialidade</span>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3 d-flex gap-2">
    <input type="hidden" asp-for="Id" />
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">
        <i class="bi bi-trash me-1"></i> Confirmar Exclusão
    </button>
    <a asp-action="Index" class="btn-secondary-custom">Cancelar</a>
</form>