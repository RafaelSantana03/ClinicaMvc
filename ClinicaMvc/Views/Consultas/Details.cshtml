@model ClinicaMvc.Models.Consulta

@{
    ViewData["Title"] = "Detalhes da Consulta";
}

<div class="page-header">
    <h2>Detalhes da Consulta</h2>
</div>

<div class="form-card" style="max-width: 500px;">
    <div class="detail-row">
        <span class="detail-label">Médico</span>
        <span class="detail-value">@Model.Medico.Nome</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Paciente</span>
        <span class="detail-value">@Model.Paciente.Nome</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Data e Hora</span>
        <span class="detail-value">@Model.DataHora.ToString("dd/MM/yyyy HH:mm")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Status</span>
        <span class="detail-value">@Model.Status</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Observações</span>
        <span class="detail-value">@(Model.Observacoes ?? "—")</span>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-custom">Editar</a>
    <a asp-action="Index" class="btn-secondary-custom">Voltar</a>
</div>