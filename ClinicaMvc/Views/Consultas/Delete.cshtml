@model ClinicaMvc.Models.Consulta

@{
    ViewData["Title"] = "Excluir Consulta";
}

<h2>Excluir Consulta</h2>

<p class="text-danger">Tem certeza que deseja excluir a consulta abaixo?</p>

<div class="card" style="max-width: 500px;">
    <div class="card-body">
        <p><strong>Médico:</strong> @Model.Medico.Nome</p>
        <p><strong>Paciente:</strong> @Model.Paciente.Nome</p>
        <p><strong>Data e Hora:</strong> @Model.DataHora.ToString("dd/MM/yyyy HH:mm")</p>
        <p><strong>Status:</strong> @Model.Status</p>
        <p><strong>Observações:</strong> @Model.Observacoes</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirmar Exclusão</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>