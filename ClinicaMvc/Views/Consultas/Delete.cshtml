@model ClinicaMvc.Models.Consulta

@{
    ViewData["Title"] = "Excluir Consulta";
}

<div class="page-header">
    <h2>Excluir Consulta</h2>
</div>

<p style="color:#EF4444; font-size:0.9rem;">
    <i class="bi bi-exclamation-triangle me-1"></i>
    Tem certeza que deseja excluir a consulta abaixo? Esta ação não pode ser desfeita.
</p>

<div class="form-card" style="max-width: 500px;">
    <div class="detail-row">
        <span class="detail-label">Médico</span>
        <span class="detail-value">@Model.Medico.Nome</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Paciente</span>
        <span class="detail-value">@Model.Paciente.Nome</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Data e Hora</span>
        <span class="detail-value">@Model.DataHora.ToString("dd/MM/yyyy HH:mm")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Status</span>
        <span class="detail-value">@Model.Status</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Observações</span>
        <span class="detail-value">@(Model.Observacoes ?? "—")</span>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3 d-flex gap-2">
    <input type="hidden" asp-for="Id" />
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger">
        <i class="bi bi-trash me-1"></i> Confirmar Exclusão
    </button>
    <a asp-action="Index" class="btn-secondary-custom">Cancelar</a>
</form>