@model ClinicaMvc.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null; // ← sem o layout padrão, tela cheia
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gerenciamento de Consultas — Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: #0F1117;
            color: #F1F5F9;
            font-family: 'Segoe UI', sans-serif;
            height: 100vh;
            display: flex;
        }

        /* LADO ESQUERDO */
        .left-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 3rem;
            background: linear-gradient(135deg, #0F1117 60%, #1a2744 100%);
            gap: 2rem;
        }

        .brand-icon {
            width: 80px;
            height: 80px;
            background-color: #1e3a6e;
            border: 2px solid #2563EB;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.2rem;
            color: #2563EB;
        }

        .brand-title {
            font-size: 2rem;
            font-weight: 700;
            text-align: center;
            color: #F1F5F9;
        }

        .brand-subtitle {
            color: #94A3B8;
            text-align: center;
            font-size: 1rem;
        }

        .feature-card {
            background-color: #1A1D27;
            border: 1px solid #2D3748;
            border-radius: 12px;
            padding: 1rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            width: 100%;
            max-width: 400px;
        }

        .feature-icon {
            width: 42px;
            height: 42px;
            background-color: #1e3a6e;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #2563EB;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .feature-text strong {
            display: block;
            color: #F1F5F9;
            font-size: 0.95rem;
        }

        .feature-text span {
            color: #94A3B8;
            font-size: 0.82rem;
        }

        /* LADO DIREITO */
        .right-panel {
            width: 480px;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #0F1117;
            padding: 2rem;
        }

        .login-card {
            background-color: #1A1D27;
            border: 1px solid #2D3748;
            border-radius: 16px;
            padding: 2.5rem;
            width: 100%;
        }

        .login-card h2 {
            text-align: center;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 0.3rem;
        }

        .login-card p {
            text-align: center;
            color: #94A3B8;
            font-size: 0.875rem;
            margin-bottom: 2rem;
        }

        .form-label {
            color: #94A3B8;
            font-size: 0.875rem;
            margin-bottom: 0.4rem;
        }

        .input-group-text {
            background-color: #0F1117;
            border: 1px solid #2D3748;
            border-right: none;
            color: #94A3B8;
        }

        .form-control {
            background-color: #0F1117;
            border: 1px solid #2D3748;
            border-left: none;
            color: #F1F5F9;
        }

        .form-control:focus {
            background-color: #0F1117;
            border-color: #2563EB;
            color: #F1F5F9;
            box-shadow: none;
        }

        .form-control::placeholder { color: #4A5568; }

        .btn-login {
            background-color: #2563EB;
            border: none;
            color: #fff;
            width: 100%;
            padding: 0.75rem;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            margin-top: 1.5rem;
            transition: background-color 0.2s;
        }

        .btn-login:hover { background-color: #3B82F6; }

        .footer-text {
            text-align: center;
            color: #4A5568;
            font-size: 0.8rem;
            margin-top: 1.5rem;
        }

        .alert-danger {
            background-color: #2d1515;
            border: 1px solid #EF4444;
            color: #EF4444;
            border-radius: 8px;
            font-size: 0.875rem;
            margin-bottom: 1rem;
        }
    </style>
</head>
<body>

    <!-- LADO ESQUERDO -->
    <div class="left-panel">
        <div class="brand-icon">
            <i class="bi bi-clipboard2-pulse"></i>
        </div>
        <div>
            <h1 class="brand-title">Gerenciamento de Consultas</h1>
            <p class="brand-subtitle">Sistema interno para clínicas</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon"><i class="bi bi-calendar-check"></i></div>
            <div class="feature-text">
                <strong>Gerencie consultas</strong>
                <span>Agende, edite e acompanhe consultas</span>
            </div>
        </div>
        <div class="feature-card">
            <div class="feature-icon"><i class="bi bi-person-badge"></i></div>
            <div class="feature-text">
                <strong>Cadastre médicos</strong>
                <span>Gerencie o corpo clínico</span>
            </div>
        </div>
        <div class="feature-card">
            <div class="feature-icon"><i class="bi bi-people"></i></div>
            <div class="feature-text">
                <strong>Cadastre pacientes</strong>
                <span>Mantenha os dados atualizados</span>
            </div>
        </div>
    </div>

    <!-- LADO DIREITO -->
    <div class="right-panel">
        <div class="login-card">
            <h2>Bem-vindo</h2>
            <p>Entre com suas credenciais para continuar</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-danger p-3">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">E-mail</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="admin@clinica.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger" style="font-size:0.8rem"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Senha</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" class="form-control" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger" style="font-size:0.8rem"></span>
                </div>
                <button type="submit" class="btn-login">Entrar</button>
            </form>

            <p class="footer-text">Sistema de uso interno — Acesso restrito</p>
        </div>
    </div>

</body>
</html>